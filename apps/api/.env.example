# Atelier API — 環境変数テンプレート
#
# このファイル (.env.example) は値を含まない雛形。git に commit する。
# 実値は各自 `cp apps/api/.env.example apps/api/.env` してから埋める。
# .env は .gitignore 済 (絶対に commit しない)。本番値は Fly secrets に投入。
#
# 取得元は SECRETS.md を参照。

# ── DB (Supabase) ─────────────────────────────────────────────
# ローカル: postgresql+asyncpg://atelier_dev:devpass@localhost:5432/atelier_dev
# 本番(Fly): Supabase Session Pooler の asyncpg URL
ATELIER_DB_URL=

# ── 認証 JWT 署名鍵 (HS256) ───────────────────────────────────
# 生成: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
ATELIER_AUTH_JWT_SECRET=

# ── Supabase Auth 連携 (本番のみ。未設定ならローカル DB direct パス) ──
ATELIER_SUPABASE_ADMIN_API_URL=
ATELIER_SUPABASE_ANON_KEY=
ATELIER_SUPABASE_SERVICE_ROLE_KEY=

# ── CORS 追加許可オリジン (カンマ区切り、任意) ────────────────
ATELIER_CORS_EXTRA_ORIGINS=

# ── AI プロバイダー (chat / RAG に必須) ───────────────────────
# 未設定だと chat は「LLM が利用できません」エラー、RAG は text 検索に degrade する。
# 本番 (Fly) にも flyctl secrets set で必ず投入する (SECRETS.md 参照)。
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# ── AI 挙動フラグ (通常は未設定のまま) ────────────────────────
# ATELIER_WEB_SEARCH_DISABLED=1   … chat の web_search tool 注入を無効化 (T-A-51)
# ATELIER_PROMPT_CACHE_DISABLED=1 … system prompt の cache_control 付与を無効化 (T-A-52)
# ATELIER_ALLOW_FAKE_LLM=1        … テスト専用 echo (本番相当検証では絶対に使わない)
