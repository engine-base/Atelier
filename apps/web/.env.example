# Atelier Web — 環境変数テンプレート
#
# 値なし雛形。`cp apps/web/.env.example apps/web/.env.local` して埋める。
# .env.local は .gitignore 済。本番値は Vercel の Environment Variables に投入。
#
# NEXT_PUBLIC_ 接頭辞の変数はブラウザ bundle に焼き込まれる (秘密にできない)。
# 公開可能な publishable key のみ NEXT_PUBLIC_ を付けること。

# ── API ベース URL ────────────────────────────────────────────
# ローカル: http://localhost:8000
# 本番: 未設定なら connector.ts が https://atelier-api-eb.fly.dev を既定使用
NEXT_PUBLIC_API_URL=

# ── Supabase (publishable のみ。secret は web に置かない) ──────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── Sentry (DSN は publishable) ───────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
