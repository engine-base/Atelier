        "file-mutex 衝突予測の表示",
        "致命級タスクある場合 経営者承認",
        "dispatcher.json 配下のパッケージを Wave スコープに並列投入"
      ]
    },
    "sprint_close": {
      "duration_min": 10,
      "checklist": [
        "Wave 完了率 (merged PR / total) 自動算出",
        "CI gate 失敗履歴のレトロ (vision 自動レポート)",
        "次 Wave 解禁条件チェック (Phase Gate 機械判定)",
        "経営者 1 クリック確認 or vision 自動進行"
      ]
    },
    "in_sprint": {
      "auto_summary_interval_h": 4,
      "channel": "S-E01-chat",
      "escalation_trigger": "CI gate 3 連続失敗"
    }
  },
  "failure_handling": [
    {
      "trigger": "CI gate 3 連続失敗",
      "action": "S-E01 + needs-human-review label"
    },
    {
      "trigger": "Wave 内 3 task 以上失敗",
      "action": "Wave 一時停止 + 緊急レトロ"
    },
    {
      "trigger": "blocking task 失敗",
      "action": "経営者通知 + Wave 全停止"
    },
    {
      "trigger": "critical gate 失敗 (R-T08 / 契約凍結)",
      "action": "経営者承認待ち"
    }
  ],
