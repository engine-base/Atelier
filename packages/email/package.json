{
  "name": "@atelier/email",
  "version": "0.1.0",
  "private": true,
  "description": "Atelier メールテンプレート (React Email)。HTML を build して dist/*.html を apps/api が読む",
  "type": "module",
  "scripts": {
    "build": "email build --src ./src/templates --outDir ./dist",
    "dev": "email dev --port 3001",
    "lint": "echo 'placeholder' && exit 0",
    "type-check": "tsc --noEmit",
    "test": "echo 'placeholder — T-F-24 で vitest に置き換え' && exit 0",
    "clean": "rm -rf dist .email"
  },
  "dependencies": {
    "@atelier/design-tokens": "workspace:*",
    "@react-email/components": "^0.0.32",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "react-email": "^3.0.4",
    "typescript": "^5.7.2"
  }
}
