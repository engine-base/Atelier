        "MCPトークン発行",
        "クライアント招待発行",
        "AI社員人格カスタマイズ（編集可項目のみ）"
      ],
      "status": "decided"
    },
    {
      "id": "R-003",
      "name": "WorkspaceMember",
      "description": "通常メンバー",
      "represented_by": "workspace_memberships.role = 'member'",
      "scope": "workspace",
      "main_permissions": [
        "プロジェクト作成・編集",
        "チャット",
        "タスク実行",
        "ナレッジ書込承認",
        "AI社員人格カスタマイズ（編集可項目のみ）"
      ],
      "status": "decided"
    },
    {
      "id": "R-004",
      "name": "WorkspaceViewer",
      "description": "閲覧者",
      "represented_by": "workspace_memberships.role = 'viewer'",
      "scope": "workspace",
      "main_permissions": [
        "全項目閲覧",
        "コメント投稿",
        "編集不可"
      ],
      "status": "decided"
    },
    {
      "id": "R-005",
      "name": "ClientGuest",
      "description": "招待されたクライアント",
      "represented_by": "JWT role = 'client_portal' (Supabase JWT カスタムclaim、別経路)",
      "scope": "project",
      "main_permissions": [
        "招待されたプロジェクトの全フェーズ閲覧",
        "コメント投稿（自分のみ編集・削除可）"
      ],
      "status": "decided",
      "isolation_note": "通常ユーザーJWTと完全分離。workspace_memberships は一切参照しない。R-T08 致命級リスク対策"
    },
    {
      "id": "R-006",
      "name": "PlatformAdmin",
      "description": "運営管理者",
      "represented_by": "auth.users.raw_app_meta_data->>'role' = 'admin'",
      "scope": "global",
      "main_permissions": [
        "スキル管理（アップロード・版管理・許可リスト）",
        "AI社員テンプレ管理",
        "ユーザー管理",
        "監査ログ閲覧",
        "プラン管理（Phase 8）"
      ],
      "status": "decided"
    }
  ],
